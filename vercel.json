{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run vercel:build",
  "installCommand": "npm install",
  "builds": [
    {
      "src": "server.mts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "dist/vercel/server.mjs"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.mts"
    }
  ]
}
