generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MealTime {
  breakfast
  lunch
  snack
  dinner
}

enum FeedbackMood {
  loved
  neutral
  could_not_finish
}

enum VolumeLevel {
  low
  medium
  high
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  name         String
  createdAt    DateTime      @default(now())
  profile      UserProfile?
  targets      NutritionTarget?
  routine      TrainingRoutine?
  budget       BudgetProfile?
  mealSlots    MealSlot[]
  feedback     MealFeedback[]
  plans        WeeklyPlan[]
  dailyVersions DailyPlanVersion[]
  adjustments  DailyPlanAdjustment[]
  waterLogs    WaterLog[]
  weightLogs   WeightLog[]
}

model UserProfile {
  id                    String   @id @default(uuid())
  userId                String   @unique
  preferredTextures     Json
  preferredVolumes      Json
  preferredFlavors      Json
  avoidedIngredients    String[]
  budgetPreference      String
  cookingTimePreference String
  safeMealIds           String[]
  favoriteMealIds       String[] @default([])
  eatingMode            String   @default("clean_bulking")
  bodyGoal              String   @default("lean_gain")
  dailyWaterTargetMl    Int      @default(2500)
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NutritionTarget {
  id           String   @id @default(uuid())
  userId       String   @unique
  bmr          Int
  tdee         Int
  calories     Int
  proteinGrams Int
  carbsGrams   Int
  fatGrams     Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TrainingRoutine {
  id                  String   @id @default(uuid())
  userId              String   @unique
  trainingDaysPerWeek Int
  trainingType        String
  preferredTimes      String[]
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BudgetProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  level             String
  maxCookingMinutes Int
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MealSlot {
  id            String   @id @default(uuid())
  userId        String
  mealTime      MealTime
  targetCalories Int
  targetProtein  Int
  position      Int
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, position])
}

model MealOption {
  id               String         @id @default(uuid())
  name             String
  mealTime         MealTime
  caloriesEstimate Int
  proteinEstimate  Int
  carbsEstimate    Int?
  fatEstimate      Int?
  budget           String
  dna              Json
  ingredients      String[]       @default([])
  recipeSteps      String[]       @default([])
  isSafeMeal       Boolean        @default(false)
  isFavorite       Boolean        @default(false)
  pausedUntil      DateTime?
  createdAt        DateTime       @default(now())
  feedback         MealFeedback[]
}

model MealFeedback {
  id              String       @id @default(uuid())
  userId          String
  mealId          String
  mood            FeedbackMood
  eatenPercentage Int
  mealTime        MealTime
  hydrationLevel  VolumeLevel?
  trainingDay     Boolean?
  userMood        String?
  occurredAt      DateTime     @default(now())
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  meal            MealOption   @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
  @@index([mealId, occurredAt])
}

model WeeklyPlan {
  id        String   @id @default(uuid())
  userId    String
  startsOn  DateTime
  content   Json
  engineVersion String @default("adaptive-weighted-v1")
  scoringWeightsVersion String @default("score-weights-v1")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startsOn])
}

model DailyPlanVersion {
  id                    String   @id @default(uuid())
  userId                String
  date                  DateTime
  version               Int
  content               Json
  previousContent       Json?
  reason                String
  engineVersion         String
  scoringWeightsVersion String
  createdAt             DateTime @default(now())
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, version])
  @@index([userId, date])
}

model DailyPlanAdjustment {
  id                    String   @id @default(uuid())
  userId                String
  date                  DateTime
  type                  String
  reason                String
  previousVersion       Int
  nextVersion           Int
  changedMeals          Json
  previousContent       Json
  nextContent           Json
  engineVersion         String
  scoringWeightsVersion String
  createdAt             DateTime @default(now())
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model WaterLog {
  id             String   @id @default(uuid())
  userId         String
  amountMilliliters Int
  occurredAt     DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
}

model WeightLog {
  id              String   @id @default(uuid())
  userId          String
  weightKilograms Float
  occurredAt      DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
}
